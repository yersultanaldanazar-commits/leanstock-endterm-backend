{
  "name": "leanstock-backend",
  "version": "1.0.0",
  "description": "LeanStock production-grade Express/Prisma backend in JavaScript with Redis reservations and forecasting",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "envalid": "^8.0.0",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.4"
  }
}
